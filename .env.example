# URL publica del sitio, usada en canonical/OG/sitemap/robots
NEXT_PUBLIC_SITE_URL=https://tipofijo.com

# Client ID de Google AdSense (ca-pub-XXXXXXXXXXXXXXXX). Si se deja vacio,
# el componente AdSlot no renderiza nada (util en desarrollo/staging antes
# de tener la cuenta de AdSense aprobada).
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# --- Seccion "vender vivienda" (captacion de leads para la agencia colaboradora) ---

# Nombre real de la agencia inmobiliaria colaboradora. Se muestra de forma
# visible junto al formulario y en /politica-privacidad. NO dejar vacio en
# produccion: mientras no este configurado, el sitio muestra un placeholder
# "[agencia colaboradora pendiente de confirmar]" (ver src/lib/partner-agency.ts).
NEXT_PUBLIC_PARTNER_AGENCY_NAME=

# Dato de contacto publico de la agencia (email o telefono), mostrado en la
# politica de privacidad para que el usuario sepa a quien se ceden sus datos.
NEXT_PUBLIC_PARTNER_AGENCY_CONTACT=

# API key de Resend (https://resend.com) usada para enviar el email de aviso
# de cada lead nuevo. Si se deja vacia, el lead se guarda solo en el log de
# auditoria local y NO se envia ningun email (ver src/app/api/leads/vender-vivienda/route.ts).
RESEND_API_KEY=

# Remitente del email de aviso de leads. Un dominio propio (p.ej.
# "TipoFijo <leads@tipofijo.com>") requiere verificarlo antes en
# https://resend.com/domains (SPF/DKIM), o Resend rechaza el envio con
# "domain is not verified" -- el SDK NO lanza excepcion en ese caso, ver el
# chequeo de `error` en src/app/api/leads/vender-vivienda/route.ts. Mientras
# no se verifique un dominio propio, usa el remitente sandbox de Resend
# (no requiere verificacion, pero solo entrega al email de la cuenta Resend):
RESEND_FROM_EMAIL="TipoFijo <onboarding@resend.dev>"

# Buzon (interno, no publico) que recibe el email de cada lead nuevo.
LEAD_NOTIFICATION_EMAIL=
